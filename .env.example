# Copy this file to .env and fill in your values

# Used by attacking agents (OpenRouter — free Hermes 3 model)
OPENROUTER_API_KEY=sk-or-YOUR-KEY-HERE

# Optional: only needed if USE_REAL_LLM=true (swaps MockVulnerableLLM in targets)
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# DRY_RUN=true means agents log payloads but don't send real HTTP requests to targets.
# Keep this true until you've verified CrewAI wiring is correct, then set to false.
DRY_RUN=true

# Set to "true" to swap target containers from MockVulnerableLLM to real Anthropic SDK.
USE_REAL_LLM=false
